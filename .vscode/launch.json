    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python runtime_tutorial_ladder: level 4",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/runtime_tutorial_ladder.py",
            "console": "integratedTerminal",
            "args": ["level4"]
        },
        {
            "name": "Python Debugger: Claw Tutorial",
            "type": "debugpy",
            "cwd": "${workspaceFolder}",
            "request": "launch",
            "program": "scripts/claw_runtime_loop.py",
            "console": "integratedTerminal",
            "args": [
                "tutorial",
                "--open-browser",
                "--reset-cdc-oplog"
            ]
        },
        {
            "name": "event bridge fastapi",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "graph_knowledge_engine.cdc.change_bridge:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8787",
                "--log-level",
                "info",
                "--access-log"
            ],
            "justMyCode": false
        },
        {
            "name": "Dump empty CDC",
            "type": "debugpy",
            "request": "launch",
            "program": "graph_knowledge_engine/utils/kge_debug_dump.py",
            "console": "integratedTerminal",
            "args": [
                "bundle",
                "--template",
                "./graph_knowledge_engine/templates/d3.html",
                "--out-dir",
                "./empty_cdc_streamer",
                "--empty",
                "--cdc-ws-url",
                "ws://127.0.0.1:8787/changes/ws"
            ],
            "justMyCode": false
        },
        {
            "name": "Dump One CDC",
            "type": "debugpy",
            "request": "launch",
            "program": "graph_knowledge_engine/utils/kge_debug_dump.py",
            "console": "integratedTerminal",
            "args": [
                "one",
                "--template",
                "./graph_knowledge_engine/templates/d3.html",
                "--out",
                "C:/Users/chanh/AppData/Local/Temp/pytest-of-chanh/pytest-810/bundle/conv.html",
                "--graph-type",
                "conversation",
                "--persist-dir",
                "C:/Users/chanh/AppData/Local/Temp/pytest-of-chanh/pytest-810/test_workflow_runtime_uses_def0/conv",
                "--cdc-ws-url",
                "ws://127.0.0.1:8787/changes/ws"
            ],
            "justMyCode": false
        },
        {
            "name": "Dump One CDC",
            "type": "debugpy",
            "request": "launch",
            "program": "graph_knowledge_engine/utils/kge_debug_dump.py",
            "console": "integratedTerminal",
            "args": [
                "one",
                "--template",
                "./graph_knowledge_engine/templates/d3.html",
                "--out",
                "C:/Users/chanh/AppData/Local/Temp/pytest-of-chanh/pytest-806/bundle/conv.html",
                "--graph-type",
                "conversation",
                "--persist-dir",
                "C:/Users/chanh/AppData/Local/Temp/pytest-of-chanh/pytest-806/test_workflow_runtime_uses_def0/conv",
                "--cdc-ws-url",
                "ws://127.0.0.1:8787/changes/ws"
            ],
            "justMyCode": false
        },
        {
            "name": "Document server mcp with admin",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "graph_knowledge_engine.server_mcp_with_admin:app",
                // "--reload",
                "--port",
                "28110",
                "--log-level",
                "debug",
            ],
            "env": {
                "MCP_CHROMA_DIR": ".document_kg_mcp" //"adjundicate"
            },
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "disposable server mcp with admin",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "graph_knowledge_engine.server_mcp_with_admin:app",
                // "--reload",
                "--port",
                "28110",
                "--log-level",
                "debug",
            ],
            "env": {
                "MCP_CHROMA_DIR": "temp" //"adjundicate"
            },
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "server mcp with admin",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "graph_knowledge_engine.server_mcp_with_admin:app",
                // "--reload",
                "--port",
                "28110",
                "--log-level",
                "debug",
            ],
            "env": {
                "MCP_CHROMA_DIR": "doc_chunk" //"adjundicate"
            },
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "server mcp with admin (keycloak oidc)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "graph_knowledge_engine.server_mcp_with_admin:app",
                // "--reload",
                "--port",
                "28110",
                "--log-level",
                "debug",
            ],
            // Assumes Keycloak is running at http://127.0.0.1:8081 (compose profile: auth)
            "env": {
                "AUTH_MODE": "oidc",
                "OIDC_DISCOVERY_URL": "http://127.0.0.1:8081/realms/kge/.well-known/openid-configuration",
                "OIDC_CLIENT_ID": "kge-local",
                "OIDC_CLIENT_SECRET": "",
                "OIDC_REDIRECT_URI": "http://127.0.0.1:28110/api/auth/callback",
                "UI_URL": "http://127.0.0.1:5173/"
            },
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "server mcp with admin (dev auth)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "graph_knowledge_engine.server_mcp_with_admin:app",
                // "--reload",
                "--port",
                "28110",
                "--log-level",
                "debug",
            ],
            // Bypasses OIDC and issues a dev JWT on /api/auth/login
            "env": {
                "AUTH_MODE": "dev",
                "DEV_AUTH_EMAIL": "dev@example.com",
                "DEV_AUTH_SUBJECT": "dev",
                "DEV_AUTH_NAME": "Dev User",
                "DEV_AUTH_ROLE": "rw",
                "DEV_AUTH_NS": "docs",
                "UI_URL": "http://127.0.0.1:5173/"
            },
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "Diagnostic, insert and check relationship exist",
            "type": "debugpy",
            "request": "launch",
            "program": ".\\diagnostic\\mcp_diag_seed.py",
            "console": "integratedTerminal",
            "args": [
                "--url",
                "http://127.0.0.1:28110/mcp/",
                "--doc-id",
                "D1",
                "--text",
                "Smoking causes lung cancer.",
                "--relation",
                "causes"
            ]
        },
        {
            "name": "Diagnostic, delete inserted",
            "type": "debugpy",
            "request": "launch",
            "program": ".\\diagnostic\\mcp_diag_seed.py",
            "console": "integratedTerminal",
            "args": [
                "--url",
                "http://127.0.0.1:28110/mcp/",
                "--doc-id",
                "D1",
                "--delete"
            ]
        },
        {
            "name": "FastMCP tool server",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "server_mcp:mcp.streamable_http_app",
                "--reload",
                "--factory",
                "--port",
                "28110"
            ],
            "jinja": true
        },
        {
            "name": "AgentMCP ",
            "type": "debugpy",
            "request": "launch",
            "program": ".\\graph_navigation_agent\\agent_mcp_l.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Current File at project root",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}